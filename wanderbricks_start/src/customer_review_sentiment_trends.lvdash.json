{
  "datasets": [
    {
      "name": "sentiment_monthly",
      "displayName": "Sentiment by Month",
      "queryLines": [
        "WITH base AS (\n",
        "  SELECT\n",
        "    DATE_FORMAT(review_date, 'yyyy-MM') AS month,\n",
        "    sentiment_label,\n",
        "    COUNT(*) AS review_count\n",
        "  FROM\n",
        "    deco_catalog.default.sentiment_reviews\n",
        "  GROUP BY\n",
        "    1,\n",
        "    2\n",
        ")\n",
        "SELECT\n",
        "  month,\n",
        "  sentiment_label,\n",
        "  review_count,\n",
        "  ROUND(review_count * 100.0 / SUM(review_count) OVER (PARTITION BY month), 1) AS pct\n",
        "FROM\n",
        "  base\n",
        "WHERE\n",
        "  month >= '2023-08'\n",
        "ORDER BY\n",
        "  1,\n",
        "  2"
      ]
    },
    {
      "name": "sentiment_scorecard",
      "displayName": "Sentiment Scorecard (Latest Month)",
      "queryLines": [
        "WITH base AS (\n",
        "  SELECT\n",
        "    DATE_FORMAT(review_date, 'yyyy-MM') AS month,\n",
        "    sentiment_label,\n",
        "    COUNT(*) AS review_count\n",
        "  FROM\n",
        "    deco_catalog.default.sentiment_reviews\n",
        "  GROUP BY\n",
        "    1,\n",
        "    2\n",
        "),\n",
        "monthly AS (\n",
        "  SELECT\n",
        "    month,\n",
        "    sentiment_label,\n",
        "    ROUND(review_count * 100.0 / SUM(review_count) OVER (PARTITION BY month), 1) AS pct\n",
        "  FROM\n",
        "    base\n",
        "),\n",
        "latest_month AS (\n",
        "  SELECT\n",
        "    MAX(month) AS max_month\n",
        "  FROM\n",
        "    monthly\n",
        ")\n",
        "SELECT\n",
        "  MAX(\n",
        "    CASE\n",
        "      WHEN sentiment_label = 'Positive' THEN pct\n",
        "    END\n",
        "  ) AS positive_pct,\n",
        "  MAX(\n",
        "    CASE\n",
        "      WHEN sentiment_label = 'Neutral' THEN pct\n",
        "    END\n",
        "  ) AS neutral_pct,\n",
        "  MAX(\n",
        "    CASE\n",
        "      WHEN sentiment_label = 'Negative' THEN pct\n",
        "    END\n",
        "  ) AS negative_pct\n",
        "FROM\n",
        "  monthly CROSS JOIN latest_month\n",
        "WHERE\n",
        "  month = max_month"
      ]
    }
  ],
